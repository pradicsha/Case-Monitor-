# =====================================================================
# Salesforce Critical & Urgent Case Monitor — example configuration
# Copy this file to `.env` and fill in your own values.
# =====================================================================

# ----- Salesforce credentials (required) -----
SALESFORCE_USERNAME=your.user@example.com
SALESFORCE_PASSWORD=your_password_here
SALESFORCE_SECURITY_TOKEN=your_security_token_here
SALESFORCE_INSTANCE=https://your-instance.my.salesforce.com

# ----- App behavior (optional) -----
# How far back to look for newly created cases (in hours)
LOOKBACK_HOURS=45

# Output filename for the styled Excel report
REPORT_FILENAME=status_report.xlsx

# Flask server settings
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=true
AUTO_OPEN_BROWSER=true

# ----- Optional SharePoint upload step -----
# Absolute path to a PowerShell script that uploads the Excel report to SharePoint.
# Leave blank to skip this step entirely. A sample script lives at scripts/upload_csv.ps1.
POWERSHELL_SCRIPT_PATH=
